{
  "name": "bash-annotator",
  "description": "Annotate Bash commands with brand-colored Nerd Font icons in Claude Code",
  "version": "0.1.0",
  "author": {
    "name": "Anthony Holten"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PLUGIN_ROOT/scripts/annotate-pre.sh"
          }
        ]
      }
    ]
  }
}
